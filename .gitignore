# Dependencies
node_modules/

# Environment variables — never commit real secrets
.env

# Runtime file uploads — gitignored; created at runtime by Multer
uploads/profiles/*
uploads/projects/*
uploads/assignments/*
uploads/certificates/*
!uploads/profiles/.gitkeep
!uploads/projects/.gitkeep
!uploads/assignments/.gitkeep
!uploads/certificates/.gitkeep

# Log files — created at runtime by Winston
logs/*.log
!logs/.gitkeep

# macOS
.DS_Store

# Editor
.vscode/
.idea/
