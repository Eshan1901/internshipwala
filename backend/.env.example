# ─────────────────────────────────────────────────────────────────────────────
# InternshipWala Backend — Environment Variables
# Copy this file to .env and fill in all values before starting the server.
# The application will refuse to start if required variables are missing.
# Never commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon format with SSL)
# Provided and managed by the database developer
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── JWT ──────────────────────────────────────────────────────────────────────
# Separate secrets for student and admin tokens (minimum 32 characters each)
STUDENT_JWT_SECRET=replace_with_a_random_string_of_at_least_64_characters
ADMIN_JWT_SECRET=replace_with_a_different_random_string_of_at_least_64_characters

# Student token expiry (e.g. 7d, 24h)
STUDENT_JWT_EXPIRY=7d

# Admin token expiry
ADMIN_JWT_EXPIRY=24h

# ── OTP ──────────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=15
OTP_LENGTH=6

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=career.internshipwala@gmail.com
SMTP_PASS=your_smtp_app_password
MAIL_FROM=InternshipWala <career.internshipwala@gmail.com>

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_PROFILE_PHOTO_SIZE_MB=2
MAX_PROJECT_FILE_SIZE_MB=10

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Auth endpoints: 20 requests per 15 minutes
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# OTP endpoints: 5 requests per 15 minutes
OTP_RATE_LIMIT_MAX=5

# Global: 100 requests per minute
GLOBAL_RATE_LIMIT_MAX=100

# ── Hard Copy Fee (fallback if not found in settings table) ──────────────────
DEFAULT_HARD_COPY_FEE=500
